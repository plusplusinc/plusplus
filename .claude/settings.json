{
  "extraKnownMarketplaces": {
    "axiom-marketplace": {
      "source": {
        "source": "github",
        "repo": "CharlesWiltgen/Axiom"
      }
    }
  },
  "enabledPlugins": {
    "axiom@axiom-marketplace": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "python3 \"$CLAUDE_PROJECT_DIR/.claude/hooks/docs-drift.py\""
          }
        ]
      }
    ]
  }
}
